generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model Character {
  id          String   @id @default(cuid())
  name        String
  referenceId String
  description String
  tags        String[]
  category    String
}


